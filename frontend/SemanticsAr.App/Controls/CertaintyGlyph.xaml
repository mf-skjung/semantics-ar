<UserControl
    x:Class="SemanticsAr.App.Controls.CertaintyGlyph"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SemanticsAr.App.Controls"
    Focusable="False">

    <Grid x:Name="Root" Width="18" Height="18">
        <Ellipse x:Name="Disc" />
        <controls:SarPieWedge x:Name="Wedge" Visibility="Collapsed" />
        <Viewbox x:Name="GlyphBox" Stretch="Uniform">
            <Canvas Width="16" Height="16">
                <Path
                    x:Name="GlyphPath"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round" />
            </Canvas>
        </Viewbox>
    </Grid>
</UserControl>
