<UserControl
    x:Class="SemanticsAr.App.Controls.ModePictogram"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SemanticsAr.App.Controls"
    Focusable="False">

    <Grid Width="220" Height="130">

        <Canvas x:Name="EnforceLayer" Width="220" Height="130">
            <Path
                Data="M12,58 L86,58 M77,50 L89,58 L77,66"
                Stroke="{DynamicResource Sar.RedBrush}"
                StrokeThickness="2.6"
                StrokeStartLineCap="Round"
                StrokeEndLineCap="Round"
                StrokeLineJoin="Round" />
            <Path
                Data="M96,48 L88,42 M97,58 L89,58 M96,68 L88,74"
                Stroke="{DynamicResource Sar.RedBrush}"
                StrokeThickness="1.8"
                StrokeStartLineCap="Round" />
            <Path
                Data="M102,30 L102,86"
                Stroke="{DynamicResource Sar.TextBrush}"
                StrokeThickness="3.6"
                StrokeStartLineCap="Round"
                StrokeEndLineCap="Round" />
            <Viewbox Canvas.Left="134" Canvas.Top="42" Width="32" Height="32">
                <Canvas Width="16" Height="16">
                    <Path
                        Data="{StaticResource Sar.Glyph.File}"
                        Stroke="{DynamicResource Sar.DefBrush}"
                        StrokeThickness="1.4"
                        StrokeLineJoin="Round" />
                </Canvas>
            </Viewbox>
            <controls:CertaintyGlyph Canvas.Left="160" Canvas.Top="66" Rung="Definitive" GlyphSize="17" />
        </Canvas>

        <Canvas x:Name="AuditLayer" Width="220" Height="130" Visibility="Collapsed">
            <Path
                Data="M12,54 L120,54 M111,46 L123,54 L111,62"
                Stroke="{DynamicResource Sar.RedBrush}"
                StrokeThickness="2.6"
                StrokeStartLineCap="Round"
                StrokeEndLineCap="Round"
                StrokeLineJoin="Round" />
            <Path
                Data="M102,26 L102,82"
                Stroke="{DynamicResource Sar.MutedBrush}"
                StrokeThickness="2"
                StrokeDashArray="1 2.4"
                StrokeDashCap="Round" />
            <Viewbox Canvas.Left="94" Canvas.Top="8" Width="16" Height="16">
                <Canvas Width="16" Height="16">
                    <Path Data="{StaticResource Sar.Glyph.Eye}" Fill="{DynamicResource Sar.BndBrush}" />
                </Canvas>
            </Viewbox>
            <Viewbox Canvas.Left="134" Canvas.Top="36" Width="30" Height="30">
                <Canvas Width="16" Height="16">
                    <Path
                        Data="{StaticResource Sar.Glyph.File}"
                        Stroke="{DynamicResource Sar.BndBrush}"
                        StrokeThickness="1.4"
                        StrokeLineJoin="Round" />
                </Canvas>
            </Viewbox>
            <Path
                Data="M140,46 L152,56 M154,45 L143,58 M147,50 L157,49"
                Stroke="{DynamicResource Sar.BndBrush}"
                StrokeThickness="1.3"
                StrokeStartLineCap="Round" />
            <Path
                Data="M102,82 L102,100 L140,100"
                Stroke="{DynamicResource Sar.MutedBrush}"
                StrokeThickness="1.2"
                StrokeLineJoin="Round" />
            <Rectangle
                Canvas.Left="140"
                Canvas.Top="88"
                Width="68"
                Height="26"
                RadiusX="6"
                RadiusY="6"
                Fill="{DynamicResource Sar.Surface3Brush}"
                Stroke="{DynamicResource Sar.HairBrush}"
                StrokeThickness="1" />
            <Viewbox Canvas.Left="147" Canvas.Top="94" Width="14" Height="14">
                <Canvas Width="16" Height="16">
                    <Path
                        Data="{StaticResource Sar.Glyph.File}"
                        Stroke="{DynamicResource Sar.MutedBrush}"
                        StrokeThickness="1.4"
                        StrokeLineJoin="Round" />
                </Canvas>
            </Viewbox>
            <Viewbox Canvas.Left="165" Canvas.Top="95" Width="15" Height="12">
                <Canvas Width="16" Height="16">
                    <Path
                        Data="{StaticResource Sar.Glyph.Key}"
                        Stroke="{DynamicResource Sar.MutedBrush}"
                        StrokeThickness="1.4"
                        StrokeStartLineCap="Round"
                        StrokeLineJoin="Round" />
                </Canvas>
            </Viewbox>
            <controls:CertaintyGlyph Canvas.Left="188" Canvas.Top="94" Rung="Definitive" GlyphSize="14" />
        </Canvas>
    </Grid>
</UserControl>
