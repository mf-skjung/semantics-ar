<UserControl
    x:Class="SemanticsAr.App.Controls.CertaintyChip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Left">

    <Border
        x:Name="ChipBorder"
        Padding="10,6"
        CornerRadius="6"
        BorderThickness="1">
        <StackPanel Orientation="Horizontal">
            <Grid Width="22" Height="22" VerticalAlignment="Center" AutomationProperties.Name="">
                <Ellipse x:Name="AccentDot" />
                <TextBlock
                    x:Name="GlyphText"
                    Foreground="White"
                    FontSize="13"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Grid>
            <TextBlock
                x:Name="LabelText"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                FontSize="14" />
        </StackPanel>
    </Border>
</UserControl>
