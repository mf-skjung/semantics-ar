<UserControl
    x:Class="SemanticsAr.App.Controls.CertaintyChip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Left">

    <Border
        x:Name="ChipBorder"
        Padding="7,3,9,3"
        BorderThickness="1"
        CornerRadius="999">
        <StackPanel Orientation="Horizontal">
            <TextBlock
                x:Name="GlyphText"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="Bold" />
            <TextBlock
                x:Name="LabelText"
                Margin="6,0,0,0"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="Bold" />
        </StackPanel>
    </Border>
</UserControl>
