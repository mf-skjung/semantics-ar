<UserControl
    x:Class="SemanticsAr.App.Controls.CertaintyChip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SemanticsAr.App.Controls"
    HorizontalAlignment="Left">

    <Border
        x:Name="ChipBorder"
        Padding="6,3,10,3"
        BorderThickness="1"
        CornerRadius="999">
        <StackPanel Orientation="Horizontal">
            <controls:CertaintyGlyph
                x:Name="Glyph"
                VerticalAlignment="Center"
                GlyphSize="15" />
            <TextBlock
                x:Name="LabelText"
                Margin="6,0,0,0"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="Bold" />
        </StackPanel>
    </Border>
</UserControl>
