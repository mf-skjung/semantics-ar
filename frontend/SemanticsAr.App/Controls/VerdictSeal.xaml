<UserControl
    x:Class="SemanticsAr.App.Controls.VerdictSeal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Focusable="False">

    <Grid x:Name="Root" Width="116" Height="116">
        <Ellipse
            x:Name="Ring"
            Width="116"
            Height="116"
            StrokeThickness="5"
            StrokeDashCap="Round" />
        <Ellipse
            x:Name="Disc"
            Width="84"
            Height="84"
            StrokeThickness="1" />
        <Viewbox
            Width="36"
            Height="36"
            Stretch="Uniform">
            <Canvas Width="16" Height="16">
                <Path
                    x:Name="GlyphPath"
                    StrokeThickness="1.7"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round" />
            </Canvas>
        </Viewbox>
    </Grid>
</UserControl>
