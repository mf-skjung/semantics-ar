<ui:FluentWindow
    x:Class="SemanticsAr.App.ModeSwitchWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:SemanticsAr.App.Controls"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:ModeControlViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Protection mode"
    Width="480"
    Background="{DynamicResource Sar.CanvasBrush}"
    FontFamily="{StaticResource Sar.Fonts.Text}"
    ResizeMode="NoResize"
    SizeToContent="Height"
    UseLayoutRounding="True"
    WindowBackdropType="None"
    WindowStartupLocation="CenterOwner"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="Protection mode"
            Background="Transparent" />

        <Grid Grid.Row="1" Margin="26,8,26,26">
            <StackPanel Visibility="{Binding ShowConfirm, Converter={StaticResource B2V}}">
                <TextBlock
                    FontFamily="{StaticResource Sar.Fonts.Display}"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Sar.TextBrush}"
                    Text="{Binding Title}" />

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="10,12" CornerRadius="12" BorderThickness="1.5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource Sar.SurfaceBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Sar.HairBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnforceAdoption}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Sar.AccentBgBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource Sar.AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Viewbox Height="94" HorizontalAlignment="Center">
                                <controls:ModePictogram IsEnforce="True" />
                            </Viewbox>
                            <TextBlock
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Sar.TextBrush}"
                                Text="Enforce" />
                            <TextBlock
                                Margin="0,3,0,0"
                                HorizontalAlignment="Center"
                                FontSize="11.5"
                                Foreground="{DynamicResource Sar.MutedBrush}"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Text="Blocks destructive encryption automatically." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="10,12" CornerRadius="12" BorderThickness="1.5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource Sar.SurfaceBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Sar.HairBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnforceAdoption}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource Sar.AccentBgBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource Sar.AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Viewbox Height="94" HorizontalAlignment="Center">
                                <controls:ModePictogram IsEnforce="False" />
                            </Viewbox>
                            <TextBlock
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Sar.TextBrush}"
                                Text="Audit" />
                            <TextBlock
                                Margin="0,3,0,0"
                                HorizontalAlignment="Center"
                                FontSize="11.5"
                                Foreground="{DynamicResource Sar.MutedBrush}"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Text="Records the attack and keeps files recoverable — does not stop it." />
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock
                    Margin="0,18,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource Sar.MutedBrush}"
                    TextWrapping="Wrap"
                    Text="{Binding Consequence}" />
                <StackPanel
                    Margin="0,22,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Click="Close_Click"
                        Content="Cancel"
                        Style="{StaticResource Sar.OutlineButton}" />
                    <Button
                        Margin="8,0,0,0"
                        Command="{Binding ConfirmCommand}"
                        Content="{Binding ConfirmLabel}"
                        Style="{StaticResource Sar.PrimaryButton}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Visibility="{Binding ShowApplied, Converter={StaticResource B2V}}">
                <TextBlock
                    FontFamily="{StaticResource Sar.Fonts.Display}"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Sar.TextBrush}"
                    Text="Mode changed" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource Sar.MutedBrush}"
                    TextWrapping="Wrap"
                    Text="{Binding ResultText}" />
                <Button
                    Margin="0,22,0,0"
                    HorizontalAlignment="Right"
                    Click="Close_Click"
                    Content="Done"
                    Style="{StaticResource Sar.PrimaryButton}" />
            </StackPanel>

            <StackPanel Visibility="{Binding ShowUnavailable, Converter={StaticResource B2V}}">
                <TextBlock
                    FontFamily="{StaticResource Sar.Fonts.Display}"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Sar.TextBrush}"
                    Text="Mode unchanged" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource Sar.MutedBrush}"
                    TextWrapping="Wrap"
                    Text="{Binding ResultText}" />
                <Button
                    Margin="0,22,0,0"
                    HorizontalAlignment="Right"
                    Click="Close_Click"
                    Content="Close"
                    Style="{StaticResource Sar.OutlineButton}" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
