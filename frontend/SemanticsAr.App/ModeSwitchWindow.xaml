<ui:FluentWindow
    x:Class="SemanticsAr.App.ModeSwitchWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:ModeControlViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Protection mode"
    Width="480"
    SizeToContent="Height"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Protection mode" />

        <Grid Grid.Row="1" Margin="24,8,24,24">
            <StackPanel Visibility="{Binding ShowConfirm, Converter={StaticResource B2V}}">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Title}" />
                <TextBlock
                    Margin="0,12,0,0"
                    Opacity="0.9"
                    TextWrapping="Wrap"
                    Text="{Binding Consequence}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Padding="16,8" Content="Cancel" Click="Close_Click" />
                    <ui:Button
                        Margin="8,0,0,0"
                        Padding="16,8"
                        Appearance="Primary"
                        Content="{Binding ConfirmLabel}"
                        Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Visibility="{Binding ShowApplied, Converter={StaticResource B2V}}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Mode changed" />
                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Text="{Binding ResultText}" />
                <ui:Button
                    Margin="0,22,0,0"
                    HorizontalAlignment="Right"
                    Padding="16,8"
                    Appearance="Primary"
                    Content="Done"
                    Click="Close_Click" />
            </StackPanel>

            <StackPanel Visibility="{Binding ShowUnavailable, Converter={StaticResource B2V}}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Mode unchanged" />
                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Text="{Binding ResultText}" />
                <Button
                    Margin="0,22,0,0"
                    HorizontalAlignment="Right"
                    Padding="16,8"
                    Content="Close"
                    Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
