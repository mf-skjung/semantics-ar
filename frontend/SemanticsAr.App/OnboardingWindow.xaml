<ui:FluentWindow
    x:Class="SemanticsAr.App.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:SemanticsAr.App.Controls"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:OnboardingViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Welcome to semantics-ar"
    Width="560"
    Height="540"
    Background="{DynamicResource Sar.CanvasBrush}"
    FontFamily="{StaticResource Sar.Fonts.Text}"
    ResizeMode="NoResize"
    UseLayoutRounding="True"
    WindowBackdropType="None"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
        <Style x:Key="StepTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Sar.Fonts.Display}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Sar.TextBrush}" />
        </Style>
        <Style x:Key="StepBody" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,14,0,0" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="{DynamicResource Sar.MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="Welcome to semantics-ar"
            Background="Transparent" />

        <Grid Grid.Row="1" Margin="30,10,30,0">
            <StackPanel Visibility="{Binding ShowWelcome, Converter={StaticResource B2V}}">
                <TextBlock Style="{StaticResource StepTitle}" Text="You're protected — here's what to expect" />
                <TextBlock Style="{StaticResource StepBody}" Text="{Binding PlatformPreempt}" />
            </StackPanel>

            <StackPanel Visibility="{Binding ShowAssets, Converter={StaticResource B2V}}">
                <TextBlock Style="{StaticResource StepTitle}" Text="Two ways your files come back — and one honest 'they don't'" />
                <controls:CertaintyLadder Margin="0,16,0,0" />
                <TextBlock
                    Margin="0,14,0,0"
                    FontSize="12"
                    Foreground="{DynamicResource Sar.FaintBrush}"
                    TextWrapping="Wrap"
                    Text="{Binding CoverageLine}" />
            </StackPanel>

            <StackPanel Visibility="{Binding ShowMode, Converter={StaticResource B2V}}">
                <TextBlock Style="{StaticResource StepTitle}" Text="Starting in AUDIT" />

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Padding="8,10" CornerRadius="10" Background="{DynamicResource Sar.SurfaceBrush}" BorderBrush="{DynamicResource Sar.HairBrush}" BorderThickness="1">
                        <StackPanel>
                            <Viewbox Height="66" HorizontalAlignment="Center">
                                <controls:ModePictogram IsEnforce="True" />
                            </Viewbox>
                            <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Sar.MutedBrush}" Text="Enforce — blocks" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="8,10" CornerRadius="10" Background="{DynamicResource Sar.AccentBgBrush}" BorderBrush="{DynamicResource Sar.AccentBrush}" BorderThickness="1.5">
                        <StackPanel>
                            <Viewbox Height="66" HorizontalAlignment="Center">
                                <controls:ModePictogram IsEnforce="False" />
                            </Viewbox>
                            <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Sar.TextBrush}" Text="Audit — records, you're here" />
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Style="{StaticResource StepBody}" Text="{Binding ModeIntro}" />
                <TextBlock
                    Margin="0,14,0,0"
                    FontSize="12.5"
                    Foreground="{DynamicResource Sar.FaintBrush}"
                    TextWrapping="Wrap"
                    Text="{Binding EnforceFuture}" />
            </StackPanel>

            <StackPanel Visibility="{Binding ShowTray, Converter={StaticResource B2V}}">
                <TextBlock Style="{StaticResource StepTitle}" Text="Keep the verdict in view" />
                <TextBlock Style="{StaticResource StepBody}" Text="{Binding TrayHelp}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="30,16,30,26">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{DynamicResource Sar.FaintBrush}"
                Text="{Binding StepLabel}" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Command="{Binding BackCommand}"
                    Content="Back"
                    Style="{StaticResource Sar.OutlineButton}"
                    Visibility="{Binding ShowBack, Converter={StaticResource B2V}}" />
                <Button
                    Margin="8,0,0,0"
                    Command="{Binding NextCommand}"
                    Content="{Binding PrimaryLabel}"
                    Style="{StaticResource Sar.PrimaryButton}" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
