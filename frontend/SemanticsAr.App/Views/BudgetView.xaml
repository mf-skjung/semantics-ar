<UserControl
    x:Class="SemanticsAr.App.Views.BudgetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:BudgetViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
    </UserControl.Resources>

    <Grid Margin="32">

        <StackPanel Visibility="{Binding ShowPreElevation, Converter={StaticResource B2V}}">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Recovery budget" />
            <TextBlock
                Margin="0,12,0,0"
                MaxWidth="640"
                Opacity="0.85"
                TextWrapping="Wrap"
                Text="{Binding Summary}" />
            <Button
                Margin="0,24,0,0"
                HorizontalAlignment="Left"
                Padding="16,8"
                Content="Open budget &amp; exemptions"
                Command="{Binding BeginCommand}" />
        </StackPanel>

        <StackPanel Visibility="{Binding ShowLoaded, Converter={StaticResource B2V}}">
            <DockPanel>
                <Button
                    DockPanel.Dock="Right"
                    VerticalAlignment="Top"
                    Padding="16,8"
                    Content="Close"
                    Command="{Binding CloseCommand}" />
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Recovery budget" />
            </DockPanel>

            <Border
                Margin="0,20,0,0"
                Padding="28"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource Status.Neutral.Brush}">
                <StackPanel>
                    <TextBlock
                        FontSize="15"
                        Opacity="0.8"
                        Text="You can restore back to" />
                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="38"
                        FontWeight="SemiBold"
                        Text="{Binding AchievedWindowText}" />
                    <TextBlock
                        Margin="0,14,0,0"
                        FontSize="14"
                        Opacity="0.85"
                        Text="{Binding CacheText}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="13"
                        Opacity="0.7"
                        Text="{Binding OldestText}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Visibility="{Binding ShowUnavailable, Converter={StaticResource B2V}}">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Budget unavailable" />
            <TextBlock
                Margin="0,12,0,0"
                MaxWidth="620"
                Opacity="0.85"
                TextWrapping="Wrap"
                Text="{Binding UnavailableText}" />
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Padding="16,8" Content="Try again" Command="{Binding BeginCommand}" />
                <Button Margin="8,0,0,0" Padding="16,8" Content="Close" Command="{Binding CloseCommand}" />
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>
