<UserControl
    x:Class="SemanticsAr.App.Views.BudgetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    xmlns:conv="clr-namespace:SemanticsAr.App.Converters"
    d:DataContext="{d:DesignInstance Type=vm:BudgetViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
        <conv:EnumToBooleanConverter x:Key="EnumBool" />
    </UserControl.Resources>

    <Grid Margin="32">

        <StackPanel Visibility="{Binding ShowPreElevation, Converter={StaticResource B2V}}">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Recovery budget" />
            <TextBlock
                Margin="0,12,0,0"
                MaxWidth="640"
                Opacity="0.85"
                TextWrapping="Wrap"
                Text="{Binding Summary}" />
            <Button
                Margin="0,24,0,0"
                HorizontalAlignment="Left"
                Padding="16,8"
                Content="Open budget"
                Command="{Binding BeginCommand}" />
        </StackPanel>

        <DockPanel Visibility="{Binding ShowLoaded, Converter={StaticResource B2V}}">
            <DockPanel DockPanel.Dock="Top">
                <Button
                    DockPanel.Dock="Right"
                    VerticalAlignment="Top"
                    Padding="16,8"
                    Content="Close"
                    Command="{Binding CloseCommand}" />
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Recovery budget" />
            </DockPanel>

            <ScrollViewer Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <Border
                        Padding="28"
                        CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource Status.Neutral.Brush}">
                        <StackPanel>
                            <TextBlock FontSize="15" Opacity="0.8" Text="You can restore back to" />
                            <TextBlock
                                Margin="0,6,0,0"
                                FontSize="38"
                                FontWeight="SemiBold"
                                Text="{Binding AchievedWindowText}" />
                            <TextBlock Margin="0,14,0,0" FontSize="14" Opacity="0.85" Text="{Binding HeldText}" />
                            <TextBlock Margin="0,4,0,0" FontSize="13" Opacity="0.7" Text="{Binding OldestText}" />

                            <Border
                                Margin="0,20,0,0"
                                Visibility="{Binding ShowTrend, Converter={StaticResource B2V}}">
                                <StackPanel>
                                    <Viewbox Height="64" HorizontalAlignment="Stretch" Stretch="Fill">
                                        <Canvas Width="560" Height="64">
                                            <Polyline
                                                Points="{Binding TrendPoints}"
                                                Stroke="{DynamicResource Status.Neutral.Brush}"
                                                StrokeThickness="2"
                                                StrokeLineJoin="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="11.5"
                                        Opacity="0.6"
                                        Text="Attributed kept copies by capture day · last 14 days" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <RadioButton
                            GroupName="range"
                            Content="24 hours"
                            IsChecked="{Binding SelectedRange, Converter={StaticResource EnumBool}, ConverterParameter=Last24Hours}"
                            AutomationProperties.Name="Last 24 hours" />
                        <RadioButton
                            Margin="16,0,0,0"
                            GroupName="range"
                            Content="7 days"
                            IsChecked="{Binding SelectedRange, Converter={StaticResource EnumBool}, ConverterParameter=Last7Days}"
                            AutomationProperties.Name="Last 7 days" />
                        <RadioButton
                            Margin="16,0,0,0"
                            GroupName="range"
                            Content="All time"
                            IsChecked="{Binding SelectedRange, Converter={StaticResource EnumBool}, ConverterParameter=AllTime}"
                            AutomationProperties.Name="All time" />
                    </StackPanel>

                    <Border
                        Margin="0,16,0,0"
                        Padding="24"
                        CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource Status.Neutral.Brush}"
                        Visibility="{Binding IsEmpty, Converter={StaticResource B2V}}">
                        <TextBlock Opacity="0.8" TextWrapping="Wrap" Text="{Binding EmptyText}" />
                    </Border>

                    <ItemsControl
                        Margin="0,12,0,0"
                        ItemsSource="{Binding Apps}"
                        Visibility="{Binding ShowApps, Converter={StaticResource B2V}}"
                        AutomationProperties.Name="Applications by budget impact">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="4"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Status.Neutral.Brush}">
                                    <StackPanel>
                                        <Button
                                            HorizontalContentAlignment="Stretch"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="12"
                                            Cursor="Hand"
                                            Command="{Binding ToggleExpandCommand}"
                                            AutomationProperties.Name="{Binding Name}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="2*" MinWidth="150" />
                                                    <ColumnDefinition Width="2*" MinWidth="140" />
                                                    <ColumnDefinition Width="2*" MinWidth="150" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Grid.Column="0"
                                                    Width="38"
                                                    Height="38"
                                                    VerticalAlignment="Center"
                                                    CornerRadius="19"
                                                    Background="{DynamicResource Status.Neutral.Brush}">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Monogram}" />
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                    <TextBlock FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Text="{Binding Name}" />
                                                    <TextBlock FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" Text="{Binding Sub}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Margin="8,0" VerticalAlignment="Center">
                                                    <ProgressBar
                                                        Height="6"
                                                        Minimum="0"
                                                        Maximum="100"
                                                        Value="{Binding SharePercent, Mode=OneWay}" />
                                                    <TextBlock
                                                        Margin="0,4,0,0"
                                                        FontSize="12"
                                                        Opacity="0.7"
                                                        Text="{Binding ShareText}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" Margin="8,0" VerticalAlignment="Center">
                                                    <TextBlock FontSize="12.5" TextWrapping="Wrap" Text="{Binding ImpactText}" />
                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        FontSize="11.5"
                                                        Opacity="0.7"
                                                        Text="{Binding DeltaText}"
                                                        Visibility="{Binding HasDelta, Converter={StaticResource B2V}}" />
                                                </StackPanel>

                                                <TextBlock
                                                    Grid.Column="4"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,4,0"
                                                    FontSize="13"
                                                    Opacity="0.6"
                                                    Text="{Binding ChevronGlyph}" />
                                            </Grid>
                                        </Button>

                                        <StackPanel
                                            Margin="12,0,12,12"
                                            Visibility="{Binding IsExpanded, Converter={StaticResource B2V}}">

                                            <ItemsControl
                                                ItemsSource="{Binding Classes}"
                                                Visibility="{Binding HasClasses, Converter={StaticResource B2V}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,4,0,0">
                                                            <TextBlock
                                                                DockPanel.Dock="Right"
                                                                FontSize="12.5"
                                                                Opacity="0.75"
                                                                Text="{Binding Detail}" />
                                                            <TextBlock FontSize="12.5" FontWeight="SemiBold" Text="{Binding Label}" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock
                                                Margin="0,10,0,0"
                                                FontSize="12.5"
                                                Opacity="0.85"
                                                Text="{Binding CostText}"
                                                Visibility="{Binding IsAttributed, Converter={StaticResource B2V}}" />

                                            <Button
                                                Margin="0,10,0,0"
                                                HorizontalAlignment="Left"
                                                Padding="12,6"
                                                Content="Exempt this app…"
                                                Command="{Binding ExemptCommand}"
                                                Visibility="{Binding CanExempt, Converter={StaticResource B2V}}"
                                                AutomationProperties.Name="Exempt this app" />

                                            <TextBlock
                                                FontSize="12.5"
                                                Opacity="0.8"
                                                MaxWidth="640"
                                                HorizontalAlignment="Left"
                                                TextWrapping="Wrap"
                                                Text="{Binding Explanation}"
                                                Visibility="{Binding ShowExplanation, Converter={StaticResource B2V}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock
                        Margin="4,10,0,0"
                        FontSize="11.5"
                        Opacity="0.55"
                        TextWrapping="Wrap"
                        Text="Aggregate view — app, coarse file type, and totals only. No per-file list is shown or kept here. Read once per visit over the elevated channel." />

                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <StackPanel Visibility="{Binding ShowUnavailable, Converter={StaticResource B2V}}">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Budget unavailable" />
            <TextBlock
                Margin="0,12,0,0"
                MaxWidth="620"
                Opacity="0.85"
                TextWrapping="Wrap"
                Text="{Binding UnavailableText}" />
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Padding="16,8" Content="Try again" Command="{Binding BeginCommand}" />
                <Button Margin="8,0,0,0" Padding="16,8" Content="Close" Command="{Binding CloseCommand}" />
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>
