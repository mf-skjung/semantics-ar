<UserControl
    x:Class="SemanticsAr.App.Views.PolicyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:PolicyViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
    </UserControl.Resources>

    <Grid Margin="32">

        <StackPanel Visibility="{Binding ShowPreElevation, Converter={StaticResource B2V}}">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Exemptions" />
            <TextBlock
                Margin="0,12,0,0"
                MaxWidth="640"
                Opacity="0.85"
                TextWrapping="Wrap"
                Text="{Binding Summary}" />
            <Button
                Margin="0,24,0,0"
                HorizontalAlignment="Left"
                Padding="16,8"
                Content="Open exemptions"
                Command="{Binding BeginCommand}" />
        </StackPanel>

        <DockPanel Visibility="{Binding ShowList, Converter={StaticResource B2V}}">
            <DockPanel DockPanel.Dock="Top">
                <Button
                    DockPanel.Dock="Right"
                    VerticalAlignment="Top"
                    Padding="16,8"
                    Content="Close"
                    Command="{Binding CloseCommand}" />
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Exemptions" />
            </DockPanel>

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,16,0,0">
                <Button Padding="16,8" Content="Add an exemption…" Command="{Binding AddByBrowseCommand}" />
            </StackPanel>

            <TextBlock
                DockPanel.Dock="Top"
                Margin="0,12,0,0"
                MaxWidth="720"
                Opacity="0.9"
                TextWrapping="Wrap"
                Text="{Binding StatusText}" />

            <Border
                DockPanel.Dock="Top"
                Margin="0,16,0,0"
                Padding="24"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource Status.Neutral.Brush}"
                Visibility="{Binding ShowEmpty, Converter={StaticResource B2V}}">
                <TextBlock Opacity="0.8" TextWrapping="Wrap" Text="No apps are exempted. Everything is being versioned. You can exempt a trusted, high-churn app here or from the Recovery budget view." />
            </Border>

            <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Exemptions}" AutomationProperties.Name="Exemptions">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="16"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource Status.Neutral.Brush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column="0"
                                        Width="38"
                                        Height="38"
                                        VerticalAlignment="Top"
                                        CornerRadius="19"
                                        Background="{DynamicResource Status.Neutral.Brush}">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="{Binding Monogram}" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock FontSize="12" Opacity="0.75" Text="{Binding Signer}" />
                                        <TextBlock FontSize="12" Opacity="0.6" Margin="0,2,0,0" Text="{Binding FirstSeenText}" />
                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="12.5"
                                            MaxWidth="560"
                                            HorizontalAlignment="Left"
                                            TextWrapping="Wrap"
                                            Opacity="0.85"
                                            Text="{Binding StateText}" />
                                    </StackPanel>

                                    <Button
                                        Grid.Column="2"
                                        VerticalAlignment="Top"
                                        Padding="12,6"
                                        Content="Stop protecting"
                                        Visibility="{Binding CanRemove, Converter={StaticResource B2V}}"
                                        Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        AutomationProperties.Name="Stop protecting this app" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <StackPanel Visibility="{Binding ShowConfirm, Converter={StaticResource B2V}}">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Stop protecting this app?" />
            <Border
                Margin="0,16,0,0"
                Padding="20"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource Status.Neutral.Brush}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding ConfirmName}" />
                    <TextBlock Margin="0,4,0,0" FontSize="12.5" Opacity="0.75" TextTrimming="CharacterEllipsis" Text="{Binding ConfirmPath}" />
                    <TextBlock Margin="0,8,0,0" FontSize="13" Text="{Binding ConfirmSigner}" />
                    <TextBlock Margin="0,2,0,0" FontSize="12" Opacity="0.7" Text="{Binding ConfirmHash}" />
                    <TextBlock Margin="0,8,0,0" FontSize="12.5" Opacity="0.9" Text="{Binding ConfirmSignatureText}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="12.5"
                        Opacity="0.85"
                        Text="{Binding ConfirmCostText}" />
                </StackPanel>
            </Border>

            <TextBlock
                Margin="0,16,0,0"
                MaxWidth="620"
                HorizontalAlignment="Left"
                FontSize="13"
                TextWrapping="Wrap"
                Foreground="{DynamicResource Status.Neutral.Brush}"
                Text="{Binding ConfirmConsequence}" />

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Padding="16,8" Content="Exempt this app" Command="{Binding ConfirmExemptActionCommand}" IsEnabled="{Binding CanConfirm}" />
                <Button Margin="8,0,0,0" Padding="16,8" Content="Cancel" Command="{Binding CancelExemptCommand}" />
            </StackPanel>
        </StackPanel>

        <StackPanel Visibility="{Binding ShowUnavailable, Converter={StaticResource B2V}}">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Exemptions unavailable" />
            <TextBlock
                Margin="0,12,0,0"
                MaxWidth="620"
                Opacity="0.85"
                TextWrapping="Wrap"
                Text="{Binding UnavailableText}" />
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Padding="16,8" Content="Try again" Command="{Binding BeginCommand}" />
                <Button Margin="8,0,0,0" Padding="16,8" Content="Close" Command="{Binding CloseCommand}" />
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>
