<UserControl
    x:Class="SemanticsAr.App.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:SemanticsAr.App.Converters"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:PostureLevelToBrushConverter x:Key="LevelToBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            x:Name="Hero"
            Grid.Row="0"
            Padding="32"
            CornerRadius="12"
            BorderThickness="1"
            BorderBrush="{Binding Level, Converter={StaticResource LevelToBrush}}"
            AutomationProperties.LiveSetting="Assertive"
            AutomationProperties.Name="{Binding AutomationText}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <Grid
                        Width="44"
                        Height="44"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="">
                        <Ellipse Fill="{Binding Level, Converter={StaticResource LevelToBrush}}" />
                        <TextBlock
                            Text="{Binding Glyph}"
                            Foreground="White"
                            FontSize="24"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock
                        Margin="18,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="34"
                        FontWeight="SemiBold"
                        Text="{Binding Headline}" />
                </StackPanel>

                <TextBlock
                    Margin="0,16,0,0"
                    MaxWidth="560"
                    HorizontalAlignment="Left"
                    FontSize="16"
                    TextWrapping="Wrap"
                    Text="{Binding Detail}" />

                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource Status.Amber.Brush}"
                    Text="Showing last known status; reconnecting…"
                    Visibility="{Binding IsStale, Converter={StaticResource BoolToVis}}" />

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <TextBlock FontSize="14" Text="{Binding ModeText}" />
                    <TextBlock
                        Margin="24,0,0,0"
                        FontSize="14"
                        Text="{Binding CapturedText}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock
            Grid.Row="1"
            Margin="4,20,4,0"
            MaxWidth="720"
            HorizontalAlignment="Left"
            FontSize="12.5"
            Opacity="0.8"
            TextWrapping="Wrap"
            Text="{x:Static vm:HomeViewModel.CoverageLine}" />
    </Grid>
</UserControl>
