<UserControl
    x:Class="SemanticsAr.App.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SemanticsAr.App.Controls"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="960" Margin="32,26,32,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ContentControl
                x:Name="Hero"
                Grid.Row="0"
                Padding="28,26"
                Style="{StaticResource Sar.Card}"
                AutomationProperties.LiveSetting="Assertive"
                AutomationProperties.Name="{Binding AutomationText}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Width="140" VerticalAlignment="Center">
                            <controls:VerdictSeal
                                HorizontalAlignment="Center"
                                Tone="{Binding SealTone}"
                                IsAudit="{Binding IsAudit}"
                                IsStale="{Binding IsStale}" />

                            <Border
                                Margin="0,16,0,0"
                                Padding="10,5"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource Sar.Surface3Brush}"
                                BorderBrush="{DynamicResource Sar.HairBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Visibility="{Binding IsEnforcing, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="11" Height="13" VerticalAlignment="Center">
                                        <Canvas Width="16" Height="16">
                                            <Path
                                                Data="{StaticResource Sar.Glyph.Bar}"
                                                Stroke="{DynamicResource Sar.TextBrush}"
                                                StrokeThickness="2.4"
                                                StrokeStartLineCap="Round"
                                                StrokeEndLineCap="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock
                                        Margin="7,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="11.5"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Sar.TextBrush}"
                                        Text="{Binding ModePillText}" />
                                </StackPanel>
                            </Border>

                            <Border
                                Margin="0,16,0,0"
                                Padding="10,5"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource Sar.BndBgBrush}"
                                BorderBrush="{DynamicResource Sar.BndLineBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Visibility="{Binding IsAudit, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse
                                        Width="7"
                                        Height="7"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource Sar.BndBrush}" />
                                    <Viewbox Width="15" Height="15" Margin="7,0,0,0" VerticalAlignment="Center">
                                        <Canvas Width="16" Height="16">
                                            <Path
                                                Data="{StaticResource Sar.Glyph.Eye}"
                                                Fill="{DynamicResource Sar.BndBrush}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock
                                        Margin="7,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="11.5"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Sar.BndBrush}"
                                        Text="{Binding ModePillText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="26,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                FontFamily="{StaticResource Sar.Fonts.Display}"
                                FontSize="27"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Sar.TextBrush}"
                                Text="{Binding Headline}" />
                            <TextBlock
                                MaxWidth="520"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Left"
                                FontSize="13.5"
                                Foreground="{DynamicResource Sar.MutedBrush}"
                                TextWrapping="Wrap"
                                Text="{Binding Detail}" />

                            <TextBlock
                                Margin="0,12,0,0"
                                FontSize="12.5"
                                Foreground="{DynamicResource Sar.BndBrush}"
                                Text="Showing last known status; reconnecting…"
                                Visibility="{Binding IsStale, Converter={StaticResource BoolToVis}}" />

                            <Border
                                Margin="0,18,0,0"
                                Padding="11,7"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource Sar.DefBgBrush}"
                                BorderBrush="{DynamicResource Sar.DefLineBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding HasCaptured, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="17" Height="17" VerticalAlignment="Center">
                                        <Canvas Width="16" Height="16">
                                            <Path
                                                Data="{StaticResource Sar.Glyph.Key}"
                                                Stroke="{DynamicResource Sar.DefBrush}"
                                                StrokeThickness="1.5"
                                                StrokeStartLineCap="Round"
                                                StrokeEndLineCap="Round"
                                                StrokeLineJoin="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock
                                        Margin="9,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Sar.DefBrush}"
                                        Text="{Binding CapturedText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ContentControl>

            <TextBlock
                Grid.Row="1"
                Margin="4,18,4,0"
                FontSize="12.5"
                Foreground="{DynamicResource Sar.FaintBrush}"
                TextWrapping="Wrap"
                Text="{x:Static vm:HomeViewModel.CoverageLine}" />
        </Grid>
    </ScrollViewer>
</UserControl>
