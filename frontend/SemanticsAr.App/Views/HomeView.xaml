<UserControl
    x:Class="SemanticsAr.App.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:SemanticsAr.App.Converters"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:PostureLevelToBrushConverter x:Key="LevelToBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="960" Margin="32,26,32,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ContentControl
                x:Name="Hero"
                Grid.Row="0"
                Padding="26,24"
                Style="{StaticResource Sar.Card}"
                AutomationProperties.LiveSetting="Assertive"
                AutomationProperties.Name="{Binding AutomationText}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="58"
                            Height="58"
                            VerticalAlignment="Center"
                            Background="{Binding Level, Converter={StaticResource LevelToBrush}, ConverterParameter=bg}"
                            BorderBrush="{Binding Level, Converter={StaticResource LevelToBrush}, ConverterParameter=line}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}"
                                Text="{Binding Glyph}" />
                        </Border>
                        <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                FontFamily="{StaticResource Sar.Fonts.Display}"
                                FontSize="27"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Sar.TextBrush}"
                                Text="{Binding Headline}" />
                            <TextBlock
                                MaxWidth="560"
                                Margin="0,4,0,0"
                                HorizontalAlignment="Left"
                                FontSize="13"
                                Foreground="{DynamicResource Sar.MutedBrush}"
                                TextWrapping="Wrap"
                                Text="{Binding Detail}" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock
                        Margin="0,12,0,0"
                        FontSize="12.5"
                        Foreground="{DynamicResource Sar.BndBrush}"
                        Text="Showing last known status; reconnecting…"
                        Visibility="{Binding IsStale, Converter={StaticResource BoolToVis}}" />

                    <Border
                        Margin="0,20,0,0"
                        Padding="0,16,0,0"
                        BorderBrush="{DynamicResource Sar.HairBrush}"
                        BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel>
                                <TextBlock
                                    FontSize="11.5"
                                    Foreground="{DynamicResource Sar.MutedBrush}"
                                    Text="Protection" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Sar.TextBrush}"
                                    Text="{Binding ModeText}" />
                            </StackPanel>
                            <StackPanel Margin="48,0,0,0">
                                <TextBlock
                                    FontSize="11.5"
                                    Foreground="{DynamicResource Sar.MutedBrush}"
                                    Text="Recoverable by key" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Sar.TextBrush}"
                                    Text="{Binding CapturedText}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ContentControl>

            <TextBlock
                Grid.Row="1"
                Margin="4,18,4,0"
                FontSize="12.5"
                Foreground="{DynamicResource Sar.FaintBrush}"
                TextWrapping="Wrap"
                Text="{x:Static vm:HomeViewModel.CoverageLine}" />
        </Grid>
    </ScrollViewer>
</UserControl>
