<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>SemanticsAr.App</AssemblyName>
    <RootNamespace>SemanticsAr.App</RootNamespace>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSdkUndockedRegFreeWinRTInitialize>true</WindowsAppSdkUndockedRegFreeWinRTInitialize>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WPF-UI" Version="4.3.0" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.4.1" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260529003" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SemanticsAr.Core\SemanticsAr.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\design-tokens\ladder.tokens.json">
      <LogicalName>SemanticsAr.App.ladder.tokens.json</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <PropertyGroup>
    <SarApiDll>$(MSBuildProjectDirectory)\..\..\build_fe\frontend\sarapi\Release\sarapi.dll</SarApiDll>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(SarApiDll)" Condition="Exists('$(SarApiDll)')" Link="sarapi.dll" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
