<ui:FluentWindow
    x:Class="SemanticsAr.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    xmlns:views="clr-namespace:SemanticsAr.App.Views"
    Title="semantics-ar"
    Width="1000"
    Height="680"
    MinWidth="760"
    MinHeight="520"
    Background="Transparent"
    FontFamily="{StaticResource Sar.Fonts.Text}"
    ExtendsContentIntoTitleBar="True"
    UseLayoutRounding="True"
    WindowBackdropType="None">

    <ui:FluentWindow.Resources>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RecoveryViewModel}">
            <views:RecoveryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BudgetViewModel}">
            <views:BudgetView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PolicyViewModel}">
            <views:PolicyView />
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Border Background="{DynamicResource Sar.CanvasBrush}" />
        <Border IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush
                    Center="-0.05,1.05"
                    GradientOrigin="-0.05,1.05"
                    MappingMode="RelativeToBoundingBox"
                    RadiusX="0.8"
                    RadiusY="0.9">
                    <GradientStop Offset="0" Color="#0A2563EB" />
                    <GradientStop Offset="1" Color="#002563EB" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>
        <Border IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush
                    Center="0.85,0.05"
                    GradientOrigin="0.85,0.05"
                    MappingMode="RelativeToBoundingBox"
                    RadiusX="0.65"
                    RadiusY="0.85">
                    <GradientStop Offset="0" Color="#080E7C66" />
                    <GradientStop Offset="1" Color="#000E7C66" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar
                Grid.Row="0"
                Title="semantics-ar"
                Background="Transparent" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="236" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" Margin="14,4,10,10">
                    <StackPanel
                        DockPanel.Dock="Top"
                        Margin="8,8,8,20"
                        Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="9">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#0E7C66" />
                                    <GradientStop Offset="1" Color="#17729B" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="S" />
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Sar.TextBrush}"
                                Text="Semantics" />
                            <TextBlock
                                Margin="0,-2,0,0"
                                FontSize="10.5"
                                Foreground="{DynamicResource Sar.FaintBrush}"
                                Text="anti-ransomware" />
                        </StackPanel>
                    </StackPanel>

                    <Button
                        DockPanel.Dock="Bottom"
                        Margin="6,12,6,4"
                        Padding="0"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="ModeChip_Click"
                        Cursor="Hand"
                        FocusVisualStyle="{StaticResource Sar.FocusVisual}"
                        IsEnabled="{Binding CanSwitchMode}"
                        ToolTip="Change protection mode"
                        AutomationProperties.Name="{Binding ModeLabel}">
                        <Border
                            Padding="11,5"
                            Background="{DynamicResource Sar.SurfaceBrush}"
                            BorderBrush="{DynamicResource Sar.HairBrush}"
                            BorderThickness="1"
                            CornerRadius="999">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse
                                    Width="6"
                                    Height="6"
                                    Margin="0,0,7,0"
                                    VerticalAlignment="Center"
                                    Fill="{DynamicResource Sar.FaintBrush}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Sar.MutedBrush}"
                                    Text="{Binding ModeLabel}" />
                            </StackPanel>
                        </Border>
                    </Button>

                    <ListBox
                        Background="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource Sar.NavItem}"
                        ItemsSource="{Binding Surfaces}"
                        KeyboardNavigation.DirectionalNavigation="Cycle"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectedItem="{Binding SelectedSurface}"
                        AutomationProperties.Name="Surfaces">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="13.5" Text="{Binding Name}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <ContentControl Grid.Column="1" Content="{Binding SelectedSurface.Content}" />
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
