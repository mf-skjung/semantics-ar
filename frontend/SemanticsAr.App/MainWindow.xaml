<ui:FluentWindow
    x:Class="SemanticsAr.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SemanticsAr.App.ViewModels"
    xmlns:views="clr-namespace:SemanticsAr.App.Views"
    Title="semantics-ar"
    Width="1000"
    Height="680"
    MinWidth="760"
    MinHeight="520"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RecoveryViewModel}">
            <views:RecoveryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BudgetViewModel}">
            <views:BudgetView />
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="semantics-ar" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="8">
                <Border
                    DockPanel.Dock="Bottom"
                    Margin="6,12,6,4"
                    Padding="10,5"
                    HorizontalAlignment="Left"
                    CornerRadius="999"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource Status.Neutral.Brush}"
                    ToolTip="Protection mode (read-only here)"
                    AutomationProperties.Name="{Binding ModeLabel}">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Status.Neutral.Brush}"
                        Text="{Binding ModeLabel}" />
                </Border>
                <ListBox
                    ItemsSource="{Binding Surfaces}"
                    SelectedItem="{Binding SelectedSurface}"
                    AutomationProperties.Name="Surfaces">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="6,10"
                                FontSize="15"
                                Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <ContentControl
                Grid.Column="1"
                Margin="8"
                Content="{Binding SelectedSurface.Content}" />
        </Grid>
    </Grid>
</ui:FluentWindow>
