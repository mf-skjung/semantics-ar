<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <Color x:Key="Sar.Color.Canvas">#FAFAF9</Color>
    <Color x:Key="Sar.Color.Surface">#FFFFFF</Color>
    <Color x:Key="Sar.Color.Surface2">#F5F4F2</Color>
    <Color x:Key="Sar.Color.Surface3">#EFEEEC</Color>
    <Color x:Key="Sar.Color.Text">#1C1B1A</Color>
    <Color x:Key="Sar.Color.Muted">#6B6A68</Color>
    <Color x:Key="Sar.Color.Faint">#8E8C89</Color>
    <Color x:Key="Sar.Color.Hair">#E7E5E4</Color>
    <Color x:Key="Sar.Color.Accent">#2563EB</Color>
    <Color x:Key="Sar.Color.AccentBg">#EEF3FE</Color>
    <Color x:Key="Sar.Color.OnAccent">#FFFFFF</Color>
    <Color x:Key="Sar.Color.Def">#0E7C66</Color>
    <Color x:Key="Sar.Color.DefBg">#E7F6F1</Color>
    <Color x:Key="Sar.Color.DefLine">#BCE4D7</Color>
    <Color x:Key="Sar.Color.Bnd">#B45309</Color>
    <Color x:Key="Sar.Color.BndBg">#FBF0DF</Color>
    <Color x:Key="Sar.Color.BndLine">#F0DBBB</Color>
    <Color x:Key="Sar.Color.Unr">#57534E</Color>
    <Color x:Key="Sar.Color.UnrBg">#F1EFEC</Color>
    <Color x:Key="Sar.Color.UnrLine">#DDD9D4</Color>
    <Color x:Key="Sar.Color.Red">#B91C1C</Color>
    <Color x:Key="Sar.Color.RedBg">#FBEDED</Color>
    <Color x:Key="Sar.Color.RedLine">#F2CFCF</Color>
    <Color x:Key="Sar.Color.BarUnattr">#C6C2BD</Color>

    <SolidColorBrush x:Key="Sar.CanvasBrush" Color="{StaticResource Sar.Color.Canvas}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.SurfaceBrush" Color="{StaticResource Sar.Color.Surface}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.Surface2Brush" Color="{StaticResource Sar.Color.Surface2}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.Surface3Brush" Color="{StaticResource Sar.Color.Surface3}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.TextBrush" Color="{StaticResource Sar.Color.Text}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.MutedBrush" Color="{StaticResource Sar.Color.Muted}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.FaintBrush" Color="{StaticResource Sar.Color.Faint}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.HairBrush" Color="{StaticResource Sar.Color.Hair}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.AccentBrush" Color="{StaticResource Sar.Color.Accent}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.AccentBgBrush" Color="{StaticResource Sar.Color.AccentBg}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.OnAccentBrush" Color="{StaticResource Sar.Color.OnAccent}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.DefBrush" Color="{StaticResource Sar.Color.Def}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.DefBgBrush" Color="{StaticResource Sar.Color.DefBg}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.DefLineBrush" Color="{StaticResource Sar.Color.DefLine}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.BndBrush" Color="{StaticResource Sar.Color.Bnd}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.BndBgBrush" Color="{StaticResource Sar.Color.BndBg}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.BndLineBrush" Color="{StaticResource Sar.Color.BndLine}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.UnrBrush" Color="{StaticResource Sar.Color.Unr}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.UnrBgBrush" Color="{StaticResource Sar.Color.UnrBg}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.UnrLineBrush" Color="{StaticResource Sar.Color.UnrLine}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.RedBrush" Color="{StaticResource Sar.Color.Red}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.RedBgBrush" Color="{StaticResource Sar.Color.RedBg}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.RedLineBrush" Color="{StaticResource Sar.Color.RedLine}" po:Freeze="True" />
    <SolidColorBrush x:Key="Sar.BarUnattrBrush" Color="{StaticResource Sar.Color.BarUnattr}" po:Freeze="True" />

    <LinearGradientBrush x:Key="Sar.BndDecayBrush" StartPoint="0,0.5" EndPoint="1,0.5" po:Freeze="True">
        <GradientStop Offset="0" Color="#FBF0DF" />
        <GradientStop Offset="0.55" Color="#FBF0DF" />
        <GradientStop Offset="0.92" Color="#00FBF0DF" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Sar.BndStripBrush" StartPoint="0,0.5" EndPoint="1,0.5" po:Freeze="True">
        <GradientStop Offset="0" Color="#B45309" />
        <GradientStop Offset="0.7" Color="#33B45309" />
        <GradientStop Offset="1" Color="#00B45309" />
    </LinearGradientBrush>

    <DropShadowEffect x:Key="Sar.Shadow.Card" BlurRadius="16" ShadowDepth="1" Direction="270" Color="#1C1B1A" Opacity="0.06" />
    <DropShadowEffect x:Key="Sar.Shadow.Large" BlurRadius="48" ShadowDepth="10" Direction="270" Color="#1C1B1A" Opacity="0.18" />

    <FontFamily x:Key="Sar.Fonts.Text">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Sar.Fonts.Display">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="Sar.Fonts.Mono">Cascadia Mono, Consolas</FontFamily>

    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource Sar.Color.Canvas}" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Sar.Color.Text}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Sar.Color.Muted}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource Sar.Color.Faint}" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Sar.Color.Hair}" />
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource Sar.Color.Hair}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource Sar.Color.Surface}" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource Sar.Color.Surface}" />
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource Sar.Color.Surface2}" />
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource Sar.Color.Surface3}" />

</ResourceDictionary>
